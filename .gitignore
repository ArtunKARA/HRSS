# Large/generated experiment output folders.
# Curated summary/table/workbook outputs are kept in this package.
ModelandPerformanceAnalysis/results/experiments/
ModelandPerformanceAnalysis/results/tuning/
ModelandPerformanceAnalysis/results/bv_suite/*
!ModelandPerformanceAnalysis/results/bv_suite/BV_BigData_Test_Suite.xlsx
!ModelandPerformanceAnalysis/results/bv_suite/bv_bigdata_suite_results.json

# Live Kafka logs are generated locally; keep only the selected metric snapshot.
SparkKafkaStreaming/results/live_metrics/*
!SparkKafkaStreaming/results/live_metrics/live_kafka_metrics_20260503-124414.jsonl

